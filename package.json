{
  "name": "devsync-gas",
  "version": "1.0.0",
  "description": "GitHub複数リポジトリからDevOps指標（DORA metrics）を収集し、Googleスプレッドシートに書き出すGASプロダクト",
  "type": "module",
  "scripts": {
    "prebuild": "test -f src/init.ts || cp src/init.fallback.ts src/init.ts",
    "build": "bun run esbuild.config.ts",
    "push": "bun run build && clasp push",
    "deploy": "bun run prepush && bun run push",
    "open": "clasp open",
    "logs": "clasp logs",
    "test": "bun test",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/ scripts/",
    "format:check": "biome format src/ scripts/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "prepare": "husky",
    "check:circular": "madge --circular --extensions ts src/",
    "check:deps": "madge --orphans --extensions ts src/",
    "check:unused": "knip",
    "check:types": "type-coverage --at-least 95",
    "check:doc": "bun run scripts/check-doc-size.ts",
    "cpd": "jscpd src --min-lines 5 --min-tokens 50",
    "check:all": "biome check src/ && bun run check:circular && bun run check:unused && bun run check:types && bunx tsc --noEmit",
    "precommit": "biome check src/ && bun test",
    "prepush": "bun run check:all && bun test && bun run build",
    "setup": "bun run scripts/setup.ts",
    "check:env": "bun run scripts/check-env.ts",
    "c": "bun run precommit",
    "p": "bun run prepush",
    "d": "bun run deploy",
    "t": "bun test",
    "l": "bun run lint",
    "f": "bun run format"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "@types/jsrsasign": "^10.5.15",
    "esbuild": "^0.20.0",
    "esbuild-gas-plugin": "^0.8.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.2.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "jsrsasign": "^11.1.0",
    "zod": "^4.3.6"
  }
}
